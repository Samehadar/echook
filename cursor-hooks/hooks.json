{
  "_comment": "Cursor IDE hooks.json template for audio-hooks. This file is the canonical template; `audio-hooks install --cursor` reads it, substitutes {{PYTHON}} and {{HOOK_RUNNER}} with absolute paths, and writes the result into ~/.cursor/hooks.json (merging with any existing user hooks). DO NOT edit ~/.cursor/hooks.json by hand — re-run install --cursor instead.",
  "_schema_doc": "https://cursor.com/docs/hooks",
  "_audio_hooks_managed": true,
  "_audio_hooks_version": "5.3.0",
  "_unsupported_in_cursor": [
    "Notification",
    "PermissionRequest"
  ],
  "_unsupported_note": "Cursor's third-party-hooks bridge maps 8 of 10 Claude Code events. Notification and PermissionRequest have no Cursor equivalent (cursor.com/docs/reference/third-party-hooks) and are intentionally absent from this hooks.json.",
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" session_start",
        "timeout": 10
      }
    ],
    "sessionEnd": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" session_end",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" stop",
        "timeout": 10,
        "loop_limit": 0
      }
    ],
    "subagentStart": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" subagent_start",
        "timeout": 10
      }
    ],
    "subagentStop": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" subagent_stop",
        "timeout": 10,
        "loop_limit": 0
      }
    ],
    "preToolUse": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" pretooluse",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" posttooluse",
        "timeout": 10
      }
    ],
    "postToolUseFailure": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" posttoolusefailure",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" file_changed",
        "timeout": 10
      }
    ],
    "preCompact": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" precompact",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" userpromptsubmit",
        "timeout": 10
      }
    ]
  }
}
