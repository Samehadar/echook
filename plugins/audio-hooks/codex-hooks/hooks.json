{
  "_comment": "Codex CLI hooks.json template for audio-hooks. This file is the canonical native-install template; `audio-hooks install --codex` reads it, substitutes {{PYTHON}} and {{HOOK_RUNNER}} with absolute paths, and writes the result into ~/.codex/hooks.json (merging with any existing user hooks). DO NOT edit ~/.codex/hooks.json by hand — re-run install --codex instead.",
  "_schema_doc": "https://developers.openai.com/codex/hooks",
  "_audio_hooks_managed": true,
  "_audio_hooks_version": "6.3.0",
  "_unsupported_in_codex": [
    "Notification",
    "SessionEnd",
    "WorktreeCreate",
    "WorktreeRemove",
    "Elicitation",
    "ElicitationResult",
    "CwdChanged",
    "FileChanged",
    "TaskCreated",
    "TaskCompleted",
    "TeammateIdle",
    "ConfigChange",
    "InstructionsLoaded",
    "PermissionDenied"
  ],
  "_unsupported_note": "Codex's hook surface covers 10 events: SessionStart, PreToolUse, PermissionRequest, PostToolUse, PreCompact, PostCompact, UserPromptSubmit, SubagentStart, SubagentStop, Stop. Other audio-hooks canonical events have no Codex equivalent and the runner no-ops them under the codex invoker.",
  "_feature_flag_required": "Codex hooks are enabled by default. `[features].hooks = false` in ~/.codex/config.toml disables all hooks; remove it or set hooks = true to re-enable. The legacy `[features].codex_hooks = true` flag is still recognized as explicitly enabled for older Codex builds.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" session_start --invoker codex",
            "timeout": 10,
            "statusMessage": "audio-hooks: session start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" pretooluse --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" posttooluse --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" permission_request --invoker codex",
            "timeout": 10,
            "statusMessage": "audio-hooks: permission request"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" precompact --invoker codex",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" precompact --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" postcompact --invoker codex",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" postcompact --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" userpromptsubmit --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" subagent_start --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" subagent_stop --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON}} \"{{HOOK_RUNNER}}\" stop --invoker codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
