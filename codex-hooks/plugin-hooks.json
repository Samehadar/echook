{
  "_comment": "Codex plugin hooks template for audio-hooks. This file is loaded by the Codex plugin manifest and uses ${PLUGIN_ROOT} so it stays relocatable inside the Codex plugin cache.",
  "_schema_doc": "https://developers.openai.com/codex/hooks",
  "_audio_hooks_managed": true,
  "_audio_hooks_version": "6.0.0",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" session_start --invoker codex",
            "timeout": 10,
            "statusMessage": "audio-hooks: session start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" pretooluse --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" permission_request --invoker codex",
            "timeout": 10,
            "statusMessage": "audio-hooks: permission request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" posttooluse --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" precompact --invoker codex",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" precompact --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" postcompact --invoker codex",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" postcompact --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" userpromptsubmit --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" subagent_start --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" subagent_stop --invoker codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${PLUGIN_ROOT}/runner/run.py\" stop --invoker codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
